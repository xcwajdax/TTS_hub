{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tts-hub.local/schemas/skin.json",
  "title": "TTS Hub Skin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "author"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "extends": { "type": "string" },
    "tokens": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "css": { "type": "string" },
    "icons": {
      "type": "object",
      "properties": {
        "filter": { "type": "string" },
        "variant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "registry": {
      "type": "object",
      "properties": {
        "homepage": { "type": "string", "format": "uri" },
        "update_url": { "type": "string", "format": "uri" },
        "manifest_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "preferences": {
      "type": "object",
      "properties": {
        "timeline_view": {
          "type": "string",
          "enum": ["bars", "bars-detailed", "line"],
          "description": "Domyślny wygląd timeline odtwarzacza po aktywacji skórki"
        }
      },
      "additionalProperties": false
    }
  }
}
