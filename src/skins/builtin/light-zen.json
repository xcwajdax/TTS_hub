{
  "id": "light-zen",
  "name": "Light / Zen",
  "version": "1.0.0",
  "author": "TTS Hub",
  "extends": "vibelife",
  "preferences": {
    "timeline_view": "line"
  },
  "tokens": {
    "color-bg": "242 238 252",
    "color-panel": "250 248 255",
    "color-panel2": "232 226 248",
    "color-border": "205 198 225",
    "color-accent": "99 82 214",
    "color-accent2": "13 148 136",
    "color-muted": "110 103 124",
    "color-text": "38 34 48",
    "color-text-heading": "24 20 36",
    "color-text-muted": "78 72 92",
    "color-bg-deep": "220 214 240",
    "color-code-bg": "234 228 248",
    "color-scrollbar-hover": "165 156 195",
    "color-text-preview": "65 58 82",
    "font-ui": "\"Inter\", ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
    "glow-accent": "0 2px 8px rgb(99 82 214 / 0.2)",
    "glow-current": "0 0 0 1px rgb(99 82 214 / 0.42), 0 4px 12px rgb(99 82 214 / 0.16)",
    "glow-playing": "0 0 0 1px rgb(13 148 136 / 0.52), 0 4px 14px rgb(13 148 136 / 0.2)",
    "gradient-primary": "linear-gradient(135deg, rgb(99 82 214) 0%, rgb(13 148 136) 100%)",
    "color-accent-soft": "99 82 214 / 0.14",
    "color-blockquote-text": "78 72 92",
    "icon-filter": "brightness(0) saturate(100%) invert(22%) sepia(12%) saturate(1200%) hue-rotate(210deg) brightness(95%) contrast(92%)"
  },
  "transition": {
    "pattern": "squares",
    "durationMs": 3200,
    "waveSpeed": 420,
    "falloff": 0.36,
    "noise": 0.12,
    "lift": 26
  },
  "css": "light-zen.css"
}
