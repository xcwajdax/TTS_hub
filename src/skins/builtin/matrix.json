{
  "id": "matrix",
  "name": "Matrix",
  "version": "1.0.0",
  "author": "TTS Hub",
  "extends": "vibelife",
  "preferences": {
    "timeline_view": "bars-detailed"
  },
  "tokens": {
    "color-bg": "0 0 0",
    "color-panel": "5 10 5",
    "color-panel2": "10 20 10",
    "color-border": "13 61 13",
    "color-accent": "0 255 65",
    "color-accent2": "0 204 51",
    "color-muted": "61 107 61",
    "color-text": "200 255 200",
    "color-text-heading": "220 255 220",
    "color-text-muted": "120 180 120",
    "color-bg-deep": "0 5 0",
    "color-code-bg": "8 18 8",
    "color-scrollbar-hover": "20 80 20",
    "color-text-preview": "140 220 140",
    "font-ui": "Consolas, \"Courier New\", ui-monospace, monospace",
    "glow-accent": "0 0 12px rgb(0 255 65 / 0.25)",
    "glow-current": "0 0 0 1px rgb(0 255 65 / 0.5), 0 0 18px rgb(0 255 65 / 0.22)",
    "glow-playing": "0 0 0 1px rgb(0 204 51 / 0.65), 0 0 22px rgb(0 204 51 / 0.28)",
    "gradient-primary": "linear-gradient(135deg, rgb(0 255 65) 0%, rgb(0 180 45) 100%)",
    "color-accent-soft": "0 255 65 / 0.08",
    "color-blockquote-text": "140 200 140",
    "icon-filter": "brightness(0) saturate(100%) invert(84%) sepia(21%) saturate(746%) hue-rotate(72deg) brightness(103%) contrast(101%)"
  },
  "transition": {
    "pattern": "matrix-columns",
    "durationMs": 4200,
    "waveSpeed": 360,
    "falloff": 0.45,
    "noise": 0.24,
    "lift": 40,
    "matrixGlyphs": true
  },
  "css": "matrix.css"
}
