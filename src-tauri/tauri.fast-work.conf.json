{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TTS Hub Fast Work",
  "version": "0.1.0",
  "identifier": "com.ttshub.fastwork",
  "build": {
    "beforeDevCommand": "npm run dev:fast-work",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build:fast-work",
    "frontendDist": "../dist-fast-work"
  },
  "app": {
    "windows": [
      {
        "label": "fast-work",
        "title": "TTS Hub Fast Work",
        "width": 420,
        "height": 560,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost https://asset.localhost ipc: http://tauri.localhost; media-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; connect-src 'self' asset: http://asset.localhost https://asset.localhost ipc: http://tauri.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
