{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "fast-work",
  "description": "Capabilities for TTS Hub Fast Work",
  "windows": ["fast-work"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "name": "open", "cmd": "" }]
    }
  ]
}
