{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TTS Hub",
  "version": "0.1.0",
  "identifier": "com.ttshub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TTS Hub",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --autoplay-policy=no-user-gesture-required"
      },
      {
        "label": "quick-setup",
        "title": "TTS Hub — Szybka konfiguracja",
        "width": 560,
        "height": 680,
        "minWidth": 480,
        "minHeight": 520,
        "resizable": true,
        "visible": false,
        "center": true,
        "fullscreen": false
      },
      {
        "label": "quick-hotkey-toast",
        "title": "TTS Hub — skrót",
        "width": 352,
        "height": 168,
        "minWidth": 280,
        "minHeight": 72,
        "maxWidth": 400,
        "maxHeight": 420,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "fullscreen": false
      },
      {
        "label": "playback-toast",
        "title": "TTS Hub — odtwarzanie",
        "width": 320,
        "height": 188,
        "minWidth": 280,
        "minHeight": 160,
        "maxWidth": 360,
        "maxHeight": 220,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:8765 http://localhost:* ipc: http://tauri.localhost; media-src 'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:8765 blob: data:; connect-src 'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:8765 http://localhost:* ws://localhost:* ipc: http://tauri.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/voicebox-server"],
    "resources": ["../.cursor-hooks/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
