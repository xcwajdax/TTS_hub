{
  "afterAgentResponse": [
    {
      "id": "tts-hub-cursor-integration",
      "command": [
        "pwsh.exe",
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy", "Bypass",
        "-File", "{{PS1_PATH}}",
        "-Phase", "capture"
      ],
      "timeout_ms": 3000
    }
  ],
  "stop": [
    {
      "id": "tts-hub-cursor-integration",
      "command": [
        "pwsh.exe",
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy", "Bypass",
        "-File", "{{PS1_PATH}}",
        "-Phase", "speak"
      ],
      "timeout_ms": 5000
    }
  ]
}
