{
  "version": 1,
  "hooks": {
    "afterAgentResponse": [
      {
        "command": "pwsh.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"{{PS1_PATH}}\" -Phase capture",
        "timeout": 3
      }
    ],
    "stop": [
      {
        "command": "pwsh.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"{{PS1_PATH}}\" -Phase speak",
        "timeout": 5
      }
    ]
  }
}
